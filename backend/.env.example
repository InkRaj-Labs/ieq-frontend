# ─────────────────────────────────────────────────────────────────────────────
# IEQ Command Center — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App Security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
API_KEY=ieq-local-dev-key-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=ieqpassword_change_me

# ── LM Studio ─────────────────────────────────────────────────────────────────
# LM Studio must be running on the HOST machine, not inside Docker
# Port 1234 is LM Studio default
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
DEFAULT_MODEL=local-model

# ── Image Generation ──────────────────────────────────────────────────────────
# Options: mock | a1111 | comfyui
IMAGE_BACKEND=mock

# Automatic1111 (if IMAGE_BACKEND=a1111)
A1111_BASE_URL=http://host.docker.internal:7860

# ComfyUI (if IMAGE_BACKEND=comfyui)
COMFYUI_BASE_URL=http://host.docker.internal:8188

# ── Frontend CORS ─────────────────────────────────────────────────────────────
# Your Vercel deployment URL
VERCEL_URL=https://ieq-frontend-kc0cdpit3-ink-raj-labs-projects.vercel.app

# ── Deployment ────────────────────────────────────────────────────────────────
# Set to the public URL of your backend (Cloudflare Tunnel domain, etc.)
# This is used by the frontend NEXT_PUBLIC_API_URL
BACKEND_PUBLIC_URL=http://localhost:8000
